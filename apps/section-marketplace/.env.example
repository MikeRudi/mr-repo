# Neon Postgres — provisioned via the Vercel Storage tab on the
# react-mr-frontend project. Locally, run:
#
#   ./node_modules/.bin/vercel link            (one-time, picks the project)
#   ./node_modules/.bin/vercel env pull .env.local
#
# That will populate this file with the live values from Vercel.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
