{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MakeReign Page Template Manifest",
  "type": "object",
  "required": ["id", "name", "category", "version", "entry"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string" },
    "version": { "type": "string" },
    "summary": { "type": "string" },
    "entry": { "type": "string" },
    "renderRoute": { "type": "string" },
    "tech": {
      "type": "object",
      "properties": {
        "framework": { "type": "string" },
        "react": { "type": "boolean" },
        "css": { "type": "array", "items": { "type": "string" } },
        "motion": { "type": "array", "items": { "type": "string" } }
      }
    },
    "wf": {
      "type": "object",
      "properties": {
        "page": { "type": "string" },
        "site": { "type": "string" }
      }
    }
  }
}
