{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MakeReign Section Manifest",
  "type": "object",
  "required": ["id", "name", "category", "version"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable kebab-case identifier, unique across the library."
    },
    "name": {
      "type": "string",
      "description": "Human-readable name shown in the marketplace UI."
    },
    "category": {
      "type": "string",
      "enum": [
        "hero",
        "intro",
        "carousel",
        "testimonials",
        "gallery",
        "features",
        "forms",
        "cta",
        "footer",
        "navigation",
        "accordion"
      ]
    },
    "version": {
      "type": "string",
      "description": "SemVer string. Bump on schema-affecting changes."
    },
    "summary": {
      "type": "string"
    },
    "entry": {
      "type": "string",
      "description": "Relative path to the section's React entry, usually 'index.jsx'."
    },
    "motion": {
      "type": "object",
      "properties": {
        "file": { "type": "string" },
        "density": {
          "type": "string",
          "enum": ["none", "low", "medium", "high"]
        }
      }
    },
    "props": {
      "type": "object",
      "description": "JSON Schema describing the props the section accepts."
    },
    "preview": {
      "type": "string",
      "description": "Relative path to the section's static preview image."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "type", "label"],
        "properties": {
          "key": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "slider",
              "select",
              "image",
              "array-object",
              "button-variant",
              "color-token",
              "typography-token",
              "number",
              "text",
              "textarea"
            ]
          },
          "label": { "type": "string" },
          "panel": {
            "type": "string",
            "enum": ["styles", "animation", "typography"]
          },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "step": { "type": "number" },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["value"],
              "properties": {
                "value": { "type": "string" },
                "label": { "type": "string" }
              }
            }
          },
          "objectFields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["key", "type", "label"],
              "properties": {
                "key": { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": [
                    "slider",
                    "select",
                    "image",
                    "button-variant",
                    "color-token",
                    "typography-token",
                    "number",
                    "text",
                    "textarea"
                  ]
                },
                "label": { "type": "string" }
              }
            }
          },
          "defaultValue": {}
        }
      }
    },
    "cms": {
      "type": "object",
      "required": ["key", "label", "fields"],
      "properties": {
        "key": { "type": "string" },
        "label": { "type": "string" },
        "defaultValue": {
          "type": "array",
          "items": { "type": "object" }
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "type", "label"],
            "properties": {
              "key": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["text", "textarea", "image", "number"]
              },
              "label": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
