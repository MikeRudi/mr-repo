{
  "id": "auto-accordion",
  "name": "Auto Accordion",
  "category": "accordion",
  "version": "0.1.0",
  "track": "stable",
  "lifecycle": "Approved",
  "description": "Vertical auto-advancing accordion. Each item carries an eyebrow, title, location, description, image, and link. The active item expands; the rest collapse. A progress bar on the active item fills over the configured duration, then auto-advances. Click an item to jump to it (auto-advance pauses).",
  "dependencies": ["gsap"],
  "motionDensity": ["medium"],
  "responsive": { "profile": "desktop / mobile-stacked" },
  "tags": ["accordion", "auto", "rotation", "split", "image"],
  "created": "2026-05-24",
  "updated": "2026-05-24",
  "submittedBy": "mike",
  "controls": [
    {
      "key": "styleVariant",
      "type": "select",
      "label": "Style variant",
      "options": [
        { "value": "editorial", "label": "Editorial" },
        { "value": "default", "label": "Default" },
        { "value": "compact", "label": "Compact" }
      ]
    },
    {
      "key": "animationStyle",
      "type": "select",
      "label": "Animation style",
      "options": [
        { "value": "slide", "label": "Slide + fade" },
        { "value": "fade", "label": "Fade only" },
        { "value": "scale", "label": "Scale + fade" }
      ]
    },
    {
      "key": "linkButtonVariant",
      "type": "button-variant",
      "label": "Link button variant"
    },
    {
      "key": "autoAdvancePct",
      "type": "slider",
      "label": "Time per item",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "revealPct",
      "type": "slider",
      "label": "Reveal speed",
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "cms": {
      "key": "items",
      "label": "Items (add / remove)",
      "defaultValue": [
        {
          "eyebrow": "Template item",
          "heading": "First accordion item",
          "subheading": "Short supporting line",
          "description": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer vitae justo sed lorem facilisis aliquet.",
          "image": "",
          "linkLabel": "Learn more",
          "linkHref": "#"
        },
        {
          "eyebrow": "Template item",
          "heading": "Second accordion item",
          "subheading": "Another supporting line",
          "description": "Praesent commodo cursus magna, vel scelerisque nisl consectetur et. Donec sed odio dui.",
          "image": "",
          "linkLabel": "Learn more",
          "linkHref": "#"
        }
      ],
      "fields": [
        { "key": "eyebrow", "type": "text", "label": "Eyebrow text" },
        { "key": "heading", "type": "text", "label": "Heading text" },
        { "key": "subheading", "type": "textarea", "label": "Sub-heading text" },
        { "key": "description", "type": "textarea", "label": "Description text" },
        { "key": "image", "type": "image", "label": "Image" },
        { "key": "linkLabel", "type": "text", "label": "Link label" },
        { "key": "linkHref", "type": "text", "label": "Link href" }
      ]
  }
}
