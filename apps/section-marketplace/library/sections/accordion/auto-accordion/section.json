{
  "id": "auto-accordion",
  "name": "Auto Accordion",
  "category": "accordion",
  "version": "0.1.0",
  "track": "stable",
  "lifecycle": "Approved",
  "description": "Vertical auto-advancing accordion. Each item carries an eyebrow, title, location, description, image, and link. The active item expands; the rest collapse. A progress bar on the active item fills over the configured duration, then auto-advances. Click an item to jump to it (auto-advance pauses).",
  "dependencies": [
    "gsap"
  ],
  "motionDensity": [
    "medium"
  ],
  "responsive": {
    "profile": "desktop / mobile-stacked"
  },
  "tags": [
    "accordion",
    "auto",
    "rotation",
    "split",
    "image"
  ],
  "created": "2026-05-24",
  "updated": "2026-05-25",
  "submittedBy": "mike",
  "controls": [
    {
      "key": "autoEnabled",
      "type": "toggle",
      "label": "Auto play",
      "defaultValue": true
    },
    {
      "key": "animationStyle",
      "type": "select",
      "label": "Animation style",
      "panel": "animation",
      "defaultValue": "slide",
      "options": [
        {
          "value": "slide",
          "label": "Slide + fade"
        },
        {
          "value": "fade",
          "label": "Fade only"
        },
        {
          "value": "scale",
          "label": "Scale + fade"
        }
      ]
    },
    {
      "key": "autoAdvancePct",
      "type": "slider",
      "label": "Time per item",
      "panel": "animation",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "revealPct",
      "type": "slider",
      "label": "Reveal speed",
      "panel": "animation",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "sectionEyebrowTypography",
      "type": "typography-token",
      "label": "Section eyebrow tag",
      "panel": "styles",
      "group": "typography",
      "defaultValue": "textSmall"
    },
    {
      "key": "sectionHeadingTypography",
      "type": "typography-token",
      "label": "Section heading tag",
      "panel": "styles",
      "group": "typography",
      "defaultValue": "h2"
    },
    {
      "key": "itemEyebrowTypography",
      "type": "typography-token",
      "label": "Item eyebrow tag",
      "panel": "styles",
      "group": "typography",
      "defaultValue": "textSmall"
    },
    {
      "key": "itemHeadingTypography",
      "type": "typography-token",
      "label": "Item heading tag",
      "panel": "styles",
      "group": "typography",
      "defaultValue": "h5"
    },
    {
      "key": "itemSubheadingTypography",
      "type": "typography-token",
      "label": "Item sub-heading tag",
      "panel": "styles",
      "group": "typography",
      "defaultValue": "textMain"
    },
    {
      "key": "itemDescriptionTypography",
      "type": "typography-token",
      "label": "Item description tag",
      "panel": "styles",
      "group": "typography",
      "defaultValue": "textSmall"
    },
    {
      "key": "splitPct",
      "type": "slider",
      "label": "Split",
      "panel": "styles",
      "group": "layout",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "imageHeightPct",
      "type": "slider",
      "label": "Image height",
      "panel": "styles",
      "group": "layout",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "reverseLayout",
      "type": "toggle",
      "label": "Reverse layout",
      "panel": "styles",
      "group": "layout",
      "defaultValue": false
    },
    {
      "key": "sectionEyebrowColor",
      "type": "color-token",
      "label": "Section eyebrow color",
      "panel": "styles",
      "group": "color",
      "defaultValue": "dark"
    },
    {
      "key": "sectionHeadingColor",
      "type": "color-token",
      "label": "Section heading color",
      "panel": "styles",
      "group": "color",
      "defaultValue": "dark"
    },
    {
      "key": "itemEyebrowColor",
      "type": "color-token",
      "label": "Item eyebrow color",
      "panel": "styles",
      "group": "color",
      "defaultValue": "dark"
    },
    {
      "key": "itemHeadingColor",
      "type": "color-token",
      "label": "Item heading color",
      "panel": "styles",
      "group": "color",
      "defaultValue": "dark"
    },
    {
      "key": "itemSubheadingColor",
      "type": "color-token",
      "label": "Item sub-heading color",
      "panel": "styles",
      "group": "color",
      "defaultValue": "dark"
    },
    {
      "key": "itemDescriptionColor",
      "type": "color-token",
      "label": "Item description color",
      "panel": "styles",
      "group": "color",
      "defaultValue": "dark"
    },
    {
      "key": "progressColor",
      "type": "color-token",
      "label": "Progress color",
      "panel": "styles",
      "group": "color",
      "defaultValue": "dark"
    },
    {
      "key": "sectionPaddingYPct",
      "type": "slider",
      "label": "Section Y padding",
      "panel": "styles",
      "group": "spacing",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "headerTextGapPct",
      "type": "slider",
      "label": "Eyebrow to heading gap",
      "panel": "styles",
      "group": "spacing",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "headerToAccordionGapPct",
      "type": "slider",
      "label": "Heading to accordion gap",
      "panel": "styles",
      "group": "spacing",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "itemHeadGapPct",
      "type": "slider",
      "label": "Item heading gap",
      "panel": "styles",
      "group": "spacing",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "itemBodyGapPct",
      "type": "slider",
      "label": "Item body gap",
      "panel": "styles",
      "group": "spacing",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "itemPaddingYPct",
      "type": "slider",
      "label": "Item Y padding",
      "panel": "styles",
      "group": "spacing",
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "key": "linkButtonVariant",
      "type": "button-variant",
      "label": "Link button variant",
      "panel": "styles",
      "group": "layout"
    },
    {
      "key": "linkButtonScalePct",
      "type": "slider",
      "label": "Link button scale",
      "panel": "styles",
      "group": "layout",
      "min": 0,
      "max": 100,
      "step": 5,
      "defaultValue": 50
    }
  ],
  "cms": {
    "key": "items",
    "label": "Items (add / remove)",
    "defaultValue": [
