{
  "name": "mr-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "library:manifest": "npm --workspace apps/section-marketplace run library:manifest",
    "db:migrate": "npm --workspace apps/section-marketplace run db:migrate"
  },
  "devDependencies": {
    "vercel": "^54.2.0"
  }
}
